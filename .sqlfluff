[sqlfluff]
dialect = postgres
templater = jinja
max_line_length = 120

# Ignore templating and parsing errors because we use the jinja templater
# rather than the dbt templater in CI (which requires db connection).
ignore = templating, parsing

# Exclude rules that are purely stylistic and cause conflicts/noise in a
# mixed-case codebase or with Jinja macros.
# CP01: keyword capitalisation (too strict for AS/FROM/etc.)
# CP03: function name capitalisation (conflicts with CP01 for AS)
# CP05: datatype capitalisation (::INTEGER vs ::integer is fine either way)
# RF04: keywords used as identifiers (e.g. 'year', 'month', 'day' via extract)
# ST02: unnecessary CASE (subjective; CASE is sometimes clearer than boolean)
exclude_rules = CP01, CP03, CP05, RF04, ST02

[sqlfluff:indentation]
tab_width = 4
indent_unit = space

[sqlfluff:rules:aliasing.table]
aliasing = explicit
